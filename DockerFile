# Use a lightweight official Python image
FROM python:3.11-slim

# Create a clean working directory inside the container
WORKDIR /app

# Copy the dependency matrix first to leverage Docker's caching layer
COPY requirements.txt .

# Install your project's pip environments cleanly
RUN pip install --no-cache-dir -r requirements.txt

# Copy over the source files, models, and asset records
COPY . .

# Expose Streamlit's default pipeline network port
EXPOSE 8501

# Configure container execution instructions
CMD ["streamlit", "run", "app.py", "--server.port=8501", "--server.address=0.0.0.0"]